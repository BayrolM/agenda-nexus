# ===========================================
# Agenda Nexus - Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# For Render: set these in the Dashboard > Environment tab.
# ===========================================

# Supabase Configuration
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Brevo (Sendinblue) - Transactional Email
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@agendanexus.com
BREVO_SENDER_NAME=Agenda Nexus

# Server
PORT=3000
NODE_ENV=development

# JWT (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here
